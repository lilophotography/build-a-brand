{
  "name": "build-a-brand-app",
  "version": "1.0.0",
  "description": "Build a Brand — LiLo Photography & Branding. Cloudflare Worker + D1 + KV + Browser Rendering.",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run",
    "db:create": "wrangler d1 create build-a-brand-db",
    "db:migrate:local": "wrangler d1 migrations apply build-a-brand-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply build-a-brand-db --remote",
    "db:console:local": "wrangler d1 execute build-a-brand-db --local --command",
    "db:console:remote": "wrangler d1 execute build-a-brand-db --remote --command"
  },
  "devDependencies": {
    "wrangler": "^4.86.0"
  }
}
